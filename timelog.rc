# timelog.rc — shared config for tw-timelog-hook and t
# Copy to: ~/.task/config/timelog.rc
#
# Include in .taskrc with:
#   include ~/.task/config/timelog.rc
#
# Used by:
#   on-modify_timelog.py  — hook: auto-logs task start/stop times
#   t                     — script: query and manage the timelog

timelog.file       = ~/.task/time/tw.timeclock
timelog.tz         = America/Toronto
timelog.ledger_bin = hledger
# timelog.editor   = vi        # defaults to $EDITOR
